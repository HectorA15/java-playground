<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="720.0" prefWidth="1280.0" stylesheets="@poisson.css"
            xmlns="http://javafx.com/javafx/25" fx:controller="tarea.simulacion.tema4.poisson.TiendaController">
    <children>
        <VBox fx:id="vboxRoot" prefHeight="615.0" prefWidth="903.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox fx:id="hboxCentral" prefHeight="351.0" prefWidth="600.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Pane fx:id="paneTienda" prefHeight="343.0" prefWidth="599.0" HBox.hgrow="ALWAYS"/>
                        <ScrollPane fx:id="scrollpaneDerecha" prefHeight="343.0" prefWidth="235.0">
                            <content>
                                <GridPane fx:id="grid" prefHeight="354.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                    </rowConstraints>
                                </GridPane>
                            </content>
                        </ScrollPane>
                    </children>
                </HBox>
                <HBox fx:id="hboxInferior" alignment="CENTER" prefHeight="61.0" prefWidth="772.0">
                    <children>
                        <TextField fx:id="txtHora" editable="false" focusTraversable="false" mouseTransparent="true"
                                   prefHeight="37.0" prefWidth="88.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                        </TextField>
                        <Region prefHeight="200.0" prefWidth="200.0"/>
                        <Label fx:id="lblPromedio" text="Promedio de llegadas (lambda)">
                            <HBox.margin>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </HBox.margin>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                        </Label>
                        <Slider fx:id="sldLambda">
                            <HBox.margin>
                                <Insets bottom="10.0" left="10.0" right="5.0" top="10.0"/>
                            </HBox.margin>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                        </Slider>
                        <TextField fx:id="txtLambda" prefHeight="37.0" prefWidth="52.0">
                            <HBox.margin>
                                <Insets bottom="10.0" left="5.0" right="10.0" top="10.0"/>
                            </HBox.margin>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                        </TextField>
                        <Button fx:id="btnIniciar" mnemonicParsing="false" onAction="#iniciarSimulacion"
                                prefHeight="37.0" prefWidth="146.0" text="Iniciar">
                            <HBox.margin>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </HBox.margin>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                        </Button>
                        <Region prefHeight="200.0" prefWidth="200.0"/>
                        <TextField fx:id="txtEstado" alignment="CENTER_RIGHT" editable="false" focusTraversable="false"
                                   mouseTransparent="true" prefHeight="25.0" prefWidth="104.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                        </TextField>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
