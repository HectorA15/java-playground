<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/25" fx:controller="tarea.simulacion.tema4.kolmogorov.KolController">
    <bottom>
        <HBox alignment="CENTER" prefHeight="32.0" prefWidth="600.0" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="lblDatos" text="Cantidad de datos">
                    <HBox.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </HBox.margin>
                </Label>
                <Slider fx:id="slider" prefHeight="24.0" prefWidth="274.0">
                    <HBox.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </HBox.margin>
                </Slider>
                <TextField fx:id="txtDatos" focusTraversable="false" prefHeight="28.0" prefWidth="53.0">
                    <HBox.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                    </HBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </padding>
                </TextField>
            </children>
        </HBox>
    </bottom>
    <top>
        <HBox alignment="CENTER" prefHeight="46.0" prefWidth="600.0" BorderPane.alignment="CENTER">
            <children>
                <Label contentDisplay="CENTER" text="Kolmogorov Smirnov">
                    <HBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </HBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </padding>
                    <font>
                        <Font name="System Bold" size="14.0"/>
                    </font>
                </Label>
                <GridPane alignment="CENTER">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <children>
                        <Label text="D maxima" GridPane.halignment="CENTER" GridPane.valignment="CENTER">
                            <font>
                                <Font name="System Bold" size="12.0"/>
                            </font>
                        </Label>
                        <Label text="Punto critico" GridPane.columnIndex="1" GridPane.halignment="CENTER"
                               GridPane.valignment="CENTER">
                            <font>
                                <Font name="System Bold" size="12.0"/>
                            </font>
                        </Label>
                        <Label fx:id="lblDplus" text="lblDp" GridPane.halignment="CENTER" GridPane.rowIndex="1"
                               GridPane.valignment="CENTER"/>
                        <Label fx:id="lblDminus" text="Label" GridPane.columnIndex="1" GridPane.halignment="CENTER"
                               GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                        <Label text="Resultado" GridPane.columnIndex="2" GridPane.halignment="CENTER"
                               GridPane.valignment="CENTER">
                            <font>
                                <Font name="System Bold" size="12.0"/>
                            </font>
                        </Label>
                        <Label fx:id="lblResultado" text="Label" GridPane.columnIndex="2" GridPane.halignment="CENTER"
                               GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                    </children>
                    <HBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </HBox.margin>
                </GridPane>
            </children>
        </HBox>
    </top>
    <center>
        <LineChart fx:id="graficoKolmogorov" prefWidth="580.0" BorderPane.alignment="CENTER">
            <xAxis>
                <NumberAxis autoRanging="false" lowerBound="0.0" side="BOTTOM" tickUnit="0.1" upperBound="1.0"/>
            </xAxis>
            <yAxis>
                <NumberAxis autoRanging="false" lowerBound="0.0" side="LEFT" tickUnit="0.1" upperBound="1.0"/>
            </yAxis>
            <BorderPane.margin>
                <Insets bottom="5.0" left="10.0" right="10.0" top="5.0"/>
            </BorderPane.margin>
        </LineChart>
    </center>
</BorderPane>
